# Copy this file to .env for local development. On Render, set these as Environment Variables instead.

# PostgreSQL connection string
# Local example:   postgresql://postgres:password@localhost:5432/splitwise
# Render example:  provided automatically if you link a Render PostgreSQL database
DATABASE_URL=postgresql://postgres:password@localhost:5432/splitwise

# Set to "false" only for local Postgres without SSL. Keep "true" (or omit) for Render.
DATABASE_SSL=true

# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the backend listens on (Render sets this automatically, but keep a local default)
PORT=5000

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_URL=http://localhost:5173
